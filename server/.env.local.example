# Copy to .env.local and fill in your Atlas connection string.
# Atlas → Cluster → Connect → Drivers → Node.js gives you this URI.
MONGODB_URI="mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=tans"
MONGODB_DB="tans"

# Clerk backend secret — Dashboard → API keys → Secret key (sk_...).
# Used to verify session tokens sent by the Expo app and to fetch the user's
# email on first sign-in. NEVER expose this in the mobile app.
CLERK_SECRET_KEY="sk_test_..."
